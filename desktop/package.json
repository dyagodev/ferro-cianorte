{
  "name": "ferro-cianorte-desktop",
  "version": "1.6.4",
  "private": true,
  "description": "DM Nexus — app desktop (bolha flutuante) para Windows e Mac",
  "author": "DM Tecnologia",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:web": "cd ../web && npm run build",
    "prepare:web": "node scripts/prepare-web.js",
    "dist:mac": "npm run build:web && npm run prepare:web && electron-builder --mac",
    "dist:win": "npm run build:web && npm run prepare:web && electron-builder --win"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0"
  },
  "build": {
    "appId": "com.dmtecnologia.dmnexus",
    "productName": "DM Nexus",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "icon": "assets/icon.png",
    "extraResources": [
      {
        "from": "web-standalone",
        "to": "web-standalone"
      }
    ],
    "publish": {
      "provider": "generic",
      "url": "https://ferro.dmtecnologia.com/desktop-updates/"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.business"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "${productName} Portable ${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
